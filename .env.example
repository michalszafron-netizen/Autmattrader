# =============================================================================
# trading-ai — environment variables template
# Skopiuj do .env (gitignored) i wypełnij prawdziwymi wartościami.
# NIGDY nie commituj .env. Używaj menedżera haseł dla sekretów.
# =============================================================================

# --- AI — modele językowe ---------------------------------------------------

# DeepSeek (główny model: hermes.py, edge_journal.py, token_research.py)
# Klucz: https://platform.deepseek.com/api_keys
DEEPSEEK_KEY=

# Grok / xAI (opcjonalny, edge_journal.py --grok)
# Klucz: https://console.x.ai/
GROK_API_KEY=

# OpenRouter (agregator, fallback gdy brak bezpośrednich kluczy)
# Klucz: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Anthropic / Claude (opcjonalny, bezpośredni)
ANTHROPIC_API_KEY=

# --- Telegram (alerty, sterowanie botem) ------------------------------------
# Utwórz bota przez @BotFather → daje TOKEN
TELEGRAM_BOT_TOKEN=
# Twoje ID: sprawdź przez @userinfobot
TELEGRAM_ALLOWED_USER_ID=
# Opcjonalnie: ID kanału/grupy dla alertów (np. -100123456789)
TELEGRAM_ALERT_CHAT_ID=

# --- Firecrawl (scraping newsów — blogwatcher.py, hermes.py) ----------------
# Klucz: https://firecrawl.dev → Dashboard → API Keys
FIRECRAWL_API_KEY=
# Drugi klucz do rotacji (blogwatcher używa dwóch naprzemiennie)
FIRECRAWL_API_KEY_2=

# --- Hyperliquid (główny execution venue) -----------------------------------
# WAŻNE: użyj API Wallet / Agent Wallet, NIE głównego portfela.
# Generuj: https://app.hyperliquid.xyz/API
# Agent wallet może tradować ale NIE może wypłacać — wbudowane zabezpieczenie protokołu.
HL_AGENT_PRIVATE_KEY=
HL_MAIN_WALLET_ADDRESS=
HL_NETWORK=mainnet
# Tryb zleceń: live = prawdziwe zlecenia | paper = tylko symulacja
HL_TRADING_MODE=paper

# --- Binance (dane rynkowe — volume_scanner.py, smart_money_tracker.py) -----
# Tylko uprawnienia READ — nigdy nie włączaj withdraw/trade dla tych kluczy
# Klucz: https://www.binance.com/en/my/settings/api-management
BINANCE_API_KEY=
BINANCE_API_SECRET=

# --- Bybit International (CEX fallback) -------------------------------------
# Klucz z IP whitelist. NIGDY nie włączaj withdraw.
BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_TESTNET=true

# --- Alpaca (US stocks, zawsze paper) ----------------------------------------
# Klucz: https://alpaca.markets → Paper Trading → API Keys
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_PAPER=true
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# --- Solana (Jupiter DEX, token_research.py) --------------------------------
SOLANA_PRIVATE_KEY=
# Główny RPC (Helius — 100k free credits/miesiąc): https://dev.helius.xyz/
SOLANA_RPC=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY
# Automatyczny fallback: Ankr (free, bez klucza) → api.mainnet-beta.solana.com

# --- Limity ryzyka (bot odmówi przekroczenia) --------------------------------
MAX_RISK_PER_TRADE_PCT=2.0
MAX_PORTFOLIO_RISK_PCT=6.0
DAILY_LOSS_KILL_SWITCH_PCT=3.0
DEFAULT_LEVERAGE=5

# --- Baza danych -------------------------------------------------------------
SQLITE_PATH=data/trading.db

# PocketBase (VPS — aktywuj po deployu na Hostinger)
# Zostaw puste żeby wyłączyć. Gdy ustawione: dane trafiają do PB i SQLite.
POCKETBASE_URL=
POCKETBASE_EMAIL=
POCKETBASE_PASSWORD=

# =============================================================================
# trading-ai — KOMPLETNY szablon zmiennych środowiskowych
# Skopiuj do .env i wypełnij wartościami.
# NIGDY nie commituj .env — jest w .gitignore.
# =============================================================================

# --- AI — modele językowe ----------------------------------------------------

# DeepSeek (GŁÓWNY model: hermes.py, edge_journal.py, token_research.py)
# Dashboard: https://platform.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# xAI / Grok (opcjonalny — edge_journal.py --grok, x_sentiment.py)
# Dashboard: https://console.x.ai
XAI_API_KEY=

# OpenRouter (fallback — 300+ modeli gdy DeepSeek niedostępny)
# Dashboard: https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Anthropic / Claude (opcjonalny — bezpośredni klucz)
ANTHROPIC_API_KEY=

# --- Telegram (alerty, sterowanie botem) ------------------------------------
# Token: @BotFather w Telegramie
TELEGRAM_BOT_TOKEN=
# Twoje ID: sprawdź przez @userinfobot
TELEGRAM_ALLOWED_USER_ID=

# --- Firecrawl (scraping newsów — blogwatcher.py, hermes.py) ----------------
# Dashboard: https://www.firecrawl.dev/app/api-keys
FIRECRAWL_API_KEY=
# Drugi klucz — blogwatcher używa dwóch naprzemiennie (rotacja limitu)
FIRECRAWL_API_KEY_2=

# --- Senpi (Hyperliquid MCP — 68 narzędzi, TradFi perps, whale scanner) -----
# Dashboard: senpi.ai → Settings → API
SENPI_AUTH_TOKEN=
SENPI_MCP_ENDPOINT=https://mcp.prod.senpi.ai

# --- Hyperliquid (główny execution venue) -----------------------------------
# WAŻNE: użyj API Wallet / Agent Wallet — NIE głównego portfela!
# Agent wallet może tradować ALE NIE może wypłacać.
# Generuj: https://app.hyperliquid.xyz/API
HL_AGENT_PRIVATE_KEY=
HL_MAIN_WALLET_ADDRESS=
HL_NETWORK=mainnet
# live = prawdziwe zlecenia | paper = tylko logi, nic nie wysyłane
HL_TRADING_MODE=paper

# --- Extended Exchange (StarkNet DEX) ----------------------------------------
EXTENDED_API_KEY=
EXTENDED_STARK_PUBLIC=
EXTENDED_VAULT=
EXTENDED_CLIENT_ID=
# live = prawdziwe zlecenia | paper = tylko logi
EXTENDED_TRADING_MODE=paper

# --- Alpaca (US stocks — ZAWSZE paper) ---------------------------------------
# Dashboard: https://alpaca.markets → Paper Trading → API Keys
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_PAPER=true
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_TRADING_MODE=paper

# --- Bybit International (CEX fallback) --------------------------------------
# Klucz z IP whitelist. NIGDY nie włączaj withdraw.
BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_TESTNET=true
BYBIT_TRADING_MODE=paper

# --- Dane rynkowe ------------------------------------------------------------

# FinnHub (kalendarz ekonomiczny — darmowy: 60 req/min)
# Dashboard: https://finnhub.io/dashboard
FINNHUB_API_KEY=

# CryptoCompare (agregator newsów — CoinDesk, CoinTelegraph, Decrypt)
# Darmowy: 11 000 calls/miesiąc | Dashboard: https://www.cryptocompare.com/cryptopian/api-keys
CRYPTOCOMPARE_API_KEY=

# Etherscan V2 (BSC + 60 sieci EVM — token_research.py)
# Darmowy: 100k calls/dzień, 5 calls/sek
# Dashboard: https://bscscan.com/myapikey
ETHERSCAN_API_KEY=

# Helius (Solana RPC + token data + holders — 100k credits/miesiąc)
# Dashboard: https://dev.helius.xyz/
HELIUS_API_KEY=

# Birdeye (Solana: ceny, OHLCV, top traders — 1k req/dzień)
# Dashboard: https://birdeye.so/
BIRDEYE_API_KEY=

# --- Solana (Jupiter DEX, token_research.py) --------------------------------
# TYLKO dedykowany wallet bota — nigdy główny portfel!
SOLANA_PRIVATE_KEY=
SOLANA_RPC=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY

# --- TradingView webhook ------------------------------------------------------
# Sekret do weryfikacji webhooków z TV Alerts
TV_SECRET=

# --- Limity ryzyka (bot odmówi przekroczenia) --------------------------------
MAX_RISK_PER_TRADE_PCT=2.0
MAX_PORTFOLIO_RISK_PCT=6.0
DAILY_LOSS_KILL_SWITCH_PCT=3.0
DEFAULT_LEVERAGE=5

# --- Tryb globalny (fallback gdy brak per-exchange klucza) -------------------
TRADING_MODE=paper

# --- Baza danych -------------------------------------------------------------
SQLITE_PATH=data/trading.db

# PocketBase (VPS — aktywuj po deployu)
# Zostaw puste żeby wyłączyć.
POCKETBASE_URL=
POCKETBASE_EMAIL=
POCKETBASE_PASSWORD=

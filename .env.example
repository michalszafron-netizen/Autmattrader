# =============================================================================
# trading-ai — environment variables template
# Copy this file to .env (which is gitignored) and fill in real values.
# NEVER commit .env. Use a password manager for actual secrets.
# =============================================================================

# --- AI ----------------------------------------------------------------------
# OpenRouter (recommended fallback aggregator). Get key: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Anthropic direct (alternative if you skip OpenRouter)
ANTHROPIC_API_KEY=

# --- Hyperliquid (primary execution venue) -----------------------------------
# IMPORTANT: Use an API WALLET / AGENT WALLET, not your main wallet.
# Generate at: https://app.hyperliquid.xyz/API
# Agent wallet can trade but CANNOT withdraw — built-in protocol safety.
HL_AGENT_PRIVATE_KEY=
HL_MAIN_WALLET_ADDRESS=
HL_NETWORK=mainnet
# Set to "testnet" while we build the bot. Switch to mainnet only after paper phase.

# --- Bybit International (CEX fallback for alts) -----------------------------
# Create read+trade API key with IP whitelist. NEVER enable withdraw.
BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_TESTNET=true

# --- Alpaca (US stocks, paper first) -----------------------------------------
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_PAPER=true
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# --- Firecrawl (optional, for news scraping) ---------------------------------
FIRECRAWL_API_KEY=

# --- Telegram (control plane, added in module 13) ----------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_ID=

# --- Risk limits (hard ceilings the bot will refuse to violate) --------------
MAX_RISK_PER_TRADE_PCT=2.0
MAX_PORTFOLIO_RISK_PCT=6.0
DAILY_LOSS_KILL_SWITCH_PCT=3.0
DEFAULT_LEVERAGE=5

# --- Mode --------------------------------------------------------------------
# paper | dry-run | live
# Start: paper. Switch to live only after 2+ weeks of clean paper logs.
TRADING_MODE=paper

# --- Solana (Jupiter DEX) ---
SOLANA_PRIVATE_KEY=
# Primary RPC (Helius recommended — 100k free credits/month)
SOLANA_RPC=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY
# Automatic fallback: Ankr (free, no key) → api.mainnet-beta.solana.com

# --- Database ----------------------------------------------------------------
# SQLite (local, always active)
SQLITE_PATH=data/trading.db

# PocketBase (VPS — activate when deployed to Hostinger)
# Leave empty to disable. When set, data is dual-written to PocketBase AND SQLite.
POCKETBASE_URL=
POCKETBASE_EMAIL=
POCKETBASE_PASSWORD=
